---
const WA_HREF = "https://wa.me/5527997402481?text=Hi%21%20I%27d%20like%20to%20book%20a%20free%20automation%20audit.";
---

<section class="hero">
  <div class="hero-ghost g1"></div>
  <div class="hero-ghost g2"></div>
  <div class="container">
    <div class="hero-grid">
      <div>
        <span class="kicker">For agencies &amp; service businesses · 90-day guarantee</span>
        <h1>Stop running your&nbsp;business.<br/>Let automation&nbsp;run&nbsp;it&nbsp;for&nbsp;you.</h1>
        <p class="subhead hero-sub">
          WFlows builds custom AI systems that cut 60–80% of manual work for marketing agencies, home-service businesses, and finance firms — giving you back the time to actually grow.
        </p>
        <div class="hero-cta">
          <a class="btn btn-primary btn-lg" href={WA_HREF} target="_blank" rel="noopener">Book a free audit →</a>
          <a class="btn btn-secondary btn-lg" href="#systems">See what we build</a>
        </div>
        <div class="hero-trust">
          <span>50+ businesses automated</span>
          <span class="hero-trust-dot">·</span>
          <span>Avg. $30K+ saved in 90 days</span>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-flow-card">
          <div class="hfc-header">
            <span class="hfc-label">Live Automation System</span>
            <span class="hfc-badge">Active</span>
          </div>
          <div class="hfc-steps">
            <div class="hfc-step done">
              <div class="hfc-step-icon">📋</div>
              <div>
                <div class="hfc-step-title">Lead Capture</div>
                <div class="hfc-step-sub">New inquiry received</div>
              </div>
              <div class="hfc-step-status triggered">Triggered</div>
            </div>
            <div class="hfc-step done">
              <div class="hfc-step-icon">🤖</div>
              <div>
                <div class="hfc-step-title">AI Qualification</div>
                <div class="hfc-step-sub">Tagged, scored, enriched</div>
              </div>
              <div class="hfc-step-status processing">→ Processing</div>
            </div>
            <div class="hfc-step">
              <div class="hfc-step-icon">✉️</div>
              <div>
                <div class="hfc-step-title">Email Nurture</div>
                <div class="hfc-step-sub">Personalized follow-up sent</div>
              </div>
            </div>
            <div class="hfc-step">
              <div class="hfc-step-icon">🔔</div>
              <div>
                <div class="hfc-step-title">Team Alert</div>
                <div class="hfc-step-sub">Sales instantly notified</div>
              </div>
            </div>
            <div class="hfc-step last">
              <div class="hfc-step-icon">🚀</div>
              <div>
                <div class="hfc-step-title">Client Onboarding</div>
                <div class="hfc-step-sub">Resources created automatically</div>
              </div>
              <div class="hfc-step-status complete">Complete</div>
            </div>
          </div>
          <div class="hfc-stats">
            <div class="hfc-stat"><span class="hfc-stat-num">12h</span><span class="hfc-stat-lbl">Saved weekly</span></div>
            <div class="hfc-stat"><span class="hfc-stat-num">0</span><span class="hfc-stat-lbl">Manual steps</span></div>
            <div class="hfc-stat"><span class="hfc-stat-num">24/7</span><span class="hfc-stat-lbl">Always running</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
