---
---

<section class="hero">
  <div class="hero-ghost g1"></div>
  <div class="hero-ghost g2"></div>
  <div class="container">
    <div class="hero-grid">
      <div>
        <span class="kicker">AI agents · GTM infra</span>
        <h1>Win More.<br/>Work Less.</h1>
        <p class="subhead hero-sub">
          We design AI-driven infrastructure for sales, service, and growth. From omnichannel automation to intelligent voice systems — we help you move with purpose, and win continuously.
        </p>
        <div class="hero-cta">
          <button class="btn btn-primary btn-lg" id="hero-cta">Build your first flow →</button>
          <button class="btn btn-secondary btn-lg">Talk to us</button>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-bento">
          <div class="cell c1">
            <div>
              <div class="cell-label">Pipeline · Live</div>
              <div class="cell-title">+38% velocity</div>
              <div class="cell-sub">7-day rolling, all sources</div>
            </div>
            <div class="mini-chart">
              <div class="bar" style={{height: '44%'}}></div>
              <div class="bar" style={{height: '28%'}}></div>
              <div class="bar" style={{height: '52%'}}></div>
              <div class="bar" style={{height: '36%'}}></div>
              <div class="bar" style={{height: '68%'}}></div>
              <div class="bar" style={{height: '40%'}}></div>
              <div class="bar" style={{height: '72%'}}></div>
              <div class="bar" style={{height: '48%'}}></div>
              <div class="bar" style={{height: '82%'}}></div>
              <div class="bar" style={{height: '60%'}}></div>
            </div>
          </div>
          <div class="cell c2">
            <div>
              <div class="cell-label">Voice agent</div>
              <div class="cell-title">Always on</div>
            </div>
            <div class="cell-sub">324 calls handled today</div>
          </div>
          <div class="cell c3">
            <div>
              <div class="cell-label">Outbound</div>
              <div class="cell-title">3.2× reply rate</div>
            </div>
            <div class="cell-sub">vs. previous 30 days</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
