---
---

<section id="how-it-works" class="py-24 bg-navy-950">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        Como <span class="text-gradient">Funciona</span>
      </h2>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        Do diagnóstico à implementação em apenas 7 dias
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
      <!-- Connection line for desktop -->
      <div class="hidden md:block absolute top-24 left-1/4 right-1/4 h-0.5 bg-gradient-to-r from-teal-400/20 via-electric-400/40 to-teal-400/20"></div>

      <!-- Step 1 -->
      <div class="relative">
        <div class="flex flex-col items-center text-center">
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-r from-teal-400 to-electric-400 rounded-full blur-xl opacity-50"></div>
            <div class="relative w-20 h-20 bg-gradient-to-r from-teal-400 to-electric-400 rounded-full flex items-center justify-center text-2xl font-bold text-navy-950">
              1
            </div>
          </div>
          <h3 class="text-2xl font-bold text-gray-100 mt-6 mb-4">Diagnóstico</h3>
          <p class="text-gray-400">
            Analisamos seus processos atuais e identificamos oportunidades onde a IA pode gerar maior impacto
          </p>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="relative">
        <div class="flex flex-col items-center text-center">
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-r from-electric-400 to-teal-400 rounded-full blur-xl opacity-50"></div>
            <div class="relative w-20 h-20 bg-gradient-to-r from-electric-400 to-teal-400 rounded-full flex items-center justify-center text-2xl font-bold text-navy-950">
              2
            </div>
          </div>
          <h3 class="text-2xl font-bold text-gray-100 mt-6 mb-4">Implementação</h3>
          <p class="text-gray-400">
            Configuramos os agentes de IA, integramos com seus sistemas e treinamos para seu negócio
          </p>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="relative">
        <div class="flex flex-col items-center text-center">
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-r from-teal-400 to-electric-400 rounded-full blur-xl opacity-50"></div>
            <div class="relative w-20 h-20 bg-gradient-to-r from-teal-400 to-electric-400 rounded-full flex items-center justify-center text-2xl font-bold text-navy-950">
              3
            </div>
          </div>
          <h3 class="text-2xl font-bold text-gray-100 mt-6 mb-4">Otimização</h3>
          <p class="text-gray-400">
            Monitoramos performance, ajustamos flows e garantimos resultados crescentes mês a mês
          </p>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-16">
      <a
        href="#contact"
        class="inline-flex items-center justify-center px-8 py-4 text-lg font-medium text-navy-950 bg-gradient-to-r from-teal-400 to-electric-400 rounded-xl hover:from-teal-300 hover:to-electric-300 transition-all duration-200 shadow-lg hover:shadow-teal-400/30 scroll-smooth"
      >
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v6a2 2 0 002 2h6a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4 4h6m-3-3v6"></path>
        </svg>
        Agendar Consulta
      </a>
    </div>
  </div>
</section>