---
---

<section id="how-it-works" class="py-28 bg-navy-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-20">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 text-white">
        Como <span class="text-teal-400">Funciona</span>
      </h2>
      <p class="text-lg sm:text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
        Do diagnóstico à implementação em <span class="font-semibold text-teal-400">apenas 7 dias</span>
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12 mb-16">
      <!-- Step 1 -->
      <div class="relative group scroll-reveal">
        <div class="flex flex-col items-start text-left bg-navy-800/30 border border-gray-700 rounded-2xl p-6 sm:p-8 hover:border-teal-400/50 hover:bg-navy-800/50 transition-all duration-300 h-full">
          <div class="flex items-center gap-4 mb-6">
            <div
              class="w-16 h-16 bg-teal-400/10 rounded-xl flex items-center justify-center flex-shrink-0 border-2 border-teal-400/30"
            >
              <svg
                class="w-8 h-8 text-teal-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"
                ></path>
              </svg>
            </div>
            <div>
              <span class="text-teal-400/60 text-sm font-medium">Dias 1-2</span>
              <h3 class="text-2xl font-bold text-white">Diagnóstico</h3>
            </div>
          </div>
          <p class="text-gray-300 leading-relaxed">
            Analisamos seus processos atuais e identificamos as oportunidades de maior impacto. Mapeamos funis, integrações e métricas existentes.
          </p>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="relative group scroll-reveal stagger-1">
        <div class="flex flex-col items-start text-left bg-navy-800/30 border border-gray-700 rounded-2xl p-6 sm:p-8 hover:border-electric-400/50 hover:bg-navy-800/50 transition-all duration-300 h-full">
          <div class="flex items-center gap-4 mb-6">
            <div
              class="w-16 h-16 bg-electric-400/10 rounded-xl flex items-center justify-center flex-shrink-0 border-2 border-electric-400/30"
            >
              <svg
                class="w-8 h-8 text-electric-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                ></path>
              </svg>
            </div>
            <div>
              <span class="text-electric-400/60 text-sm font-medium">Dias 3-5</span>
              <h3 class="text-2xl font-bold text-white">Implementação</h3>
            </div>
          </div>
          <p class="text-gray-300 leading-relaxed">
            Configuramos os agentes de IA, integramos com CRM e ferramentas existentes, e treinamos os sistemas com suas especificações de negócio.
          </p>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="relative group scroll-reveal stagger-2">
        <div class="flex flex-col items-start text-left bg-navy-800/30 border border-gray-700 rounded-2xl p-6 sm:p-8 hover:border-teal-400/50 hover:bg-navy-800/50 transition-all duration-300 h-full">
          <div class="flex items-center gap-4 mb-6">
            <div
              class="w-16 h-16 bg-teal-400/10 rounded-xl flex items-center justify-center flex-shrink-0 border-2 border-teal-400/30"
            >
              <svg
                class="w-8 h-8 text-teal-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"
                ></path>
              </svg>
            </div>
            <div>
              <span class="text-teal-400/60 text-sm font-medium">Dias 6-7+</span>
              <h3 class="text-2xl font-bold text-white">Otimização</h3>
            </div>
          </div>
          <p class="text-gray-300 leading-relaxed">
            Monitoramos performance em tempo real, ajustamos flows conforme necessário e garantimos resultados crescentes mês a mês.
          </p>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center">
      <a
        href="#contact"
        class="inline-flex items-center justify-center px-8 py-4 text-base sm:text-lg font-semibold text-navy-950 bg-gradient-to-r from-teal-400 to-electric-400 rounded-xl hover:from-teal-300 hover:to-electric-300 hover:scale-105 active:scale-100 shadow-lg hover:shadow-teal-400/50"
      >
        <svg
          class="w-5 h-5 mr-2 flex-shrink-0"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
          ></path>
        </svg>
        Agendar Consulta
      </a>
    </div>
  </div>
</section>