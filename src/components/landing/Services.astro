---

---

<section id="services" class="py-32 bg-navy-900/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-20">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 text-white">
        Nossos <span class="text-teal-400">Flows</span>
      </h2>
      <p class="text-lg sm:text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
        Soluções de IA que preveem oportunidades e automatizam todo o ciclo
        comercial
      </p>
    </div>

    <!-- Featured service - SDR Artificial -->
    <div class="mb-12 scroll-reveal">
      <div class="relative group">
        <div
          class="relative bg-gradient-to-br from-navy-800 to-navy-900 border-2 border-teal-400/50 rounded-2xl p-8 sm:p-10 hover:border-teal-400 hover:shadow-xl hover:shadow-teal-400/20 transition-all duration-300"
        >
          <div class="flex items-start justify-between mb-6">
            <div
              class="w-14 h-14 bg-gradient-to-r from-teal-400 to-electric-400 rounded-xl flex items-center justify-center flex-shrink-0"
            >
              <svg
                class="w-7 h-7 text-navy-950"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                ></path>
              </svg>
            </div>
            <span
              class="inline-flex items-center px-3 py-1 bg-teal-400/10 text-teal-400 text-xs font-semibold rounded-full border border-teal-400/20"
            >
              Mais Popular
            </span>
          </div>
          <h3 class="text-2xl sm:text-3xl font-bold text-white mb-4">
            SDR Artificial 24/7
          </h3>
          <p class="text-lg text-gray-300 mb-6 leading-relaxed">
            Atendimento comercial inteligente que qualifica leads, agenda
            reuniões e alimenta seu CRM automaticamente — sem parar nunca.
          </p>
          <ul class="space-y-3 mb-8">
            <li class="flex items-start gap-3">
              <svg
                class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-200">Qualificação inteligente de leads</span>
            </li>
            <li class="flex items-start gap-3">
              <svg
                class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-200">Agendamento automático de reuniões</span>
            </li>
            <li class="flex items-start gap-3">
              <svg
                class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-200">Integração total com CRM</span>
            </li>
            <li class="flex items-start gap-3">
              <svg
                class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-200">Follow-up personalizado e persistente</span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Other services grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Análise Preditiva -->
      <div class="relative group">
        <div
          class="relative bg-navy-800/50 backdrop-blur-sm border border-gray-700 rounded-2xl p-6 hover:border-teal-400/50 hover:bg-navy-800/70 transition-all duration-300 h-full"
        >
          <div
            class="w-12 h-12 bg-teal-400/10 rounded-lg flex items-center justify-center mb-5 border border-teal-400/20"
          >
            <svg
              class="w-6 h-6 text-teal-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-100 mb-3">
            Análise Preditiva de Marketing
          </h3>
          <p class="text-sm text-gray-400 mb-5 leading-relaxed">
            Sistemas que analisam seus dados de tráfego, conversões e
            comportamento para prever tendências e identificar oportunidades.
          </p>
          <ul class="space-y-2 text-sm text-gray-400">
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-teal-400 shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Previsão de ROI por canal</span>
            </li>
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-teal-400 shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Identificação de gargalos automatizada</span>
            </li>
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-teal-400 shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Recomendações de otimização em tempo real</span>
            </li>
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-teal-400 shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Dashboards executivos inteligentes</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Captação e Nutrição -->
      <div class="relative group">
        <div
          class="relative bg-navy-800/50 backdrop-blur-sm border border-gray-700 rounded-2xl p-6 hover:border-teal-400/50 hover:bg-navy-800/70 transition-all duration-300 h-full"
        >
          <div
            class="w-12 h-12 bg-electric-400/10 rounded-lg flex items-center justify-center mb-5 border border-electric-400/20"
          >
            <svg
              class="w-6 h-6 text-electric-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-100 mb-3">
            Captação e Nutrição Inteligente
          </h3>
          <p class="text-sm text-gray-400 leading-relaxed">
            Sistemas que atraem, capturam, segmentam e nutrem leads
            automaticamente até o momento ideal de conversão.
          </p>
        </div>
      </div>

      <!-- Automação Comercial -->
      <div class="relative group">
        <div
          class="relative bg-navy-800/50 backdrop-blur-sm border border-gray-700 rounded-2xl p-6 hover:border-teal-400/50 hover:bg-navy-800/70 transition-all duration-300 h-full"
        >
          <div
            class="w-12 h-12 bg-teal-400/10 rounded-lg flex items-center justify-center mb-5 border border-teal-400/20"
          >
            <svg
              class="w-6 h-6 text-teal-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-100 mb-3">
            Automação Comercial Completa
          </h3>
          <p class="text-sm text-gray-400 leading-relaxed">
            Da prospecção ao fechamento, sistemas que multiplicam sua capacidade
            comercial sem aumentar a equipe.
          </p>
        </div>
      </div>

      <!-- Desenvolvimento Sob Medida -->
      <div class="relative group">
        <div
          class="relative bg-navy-800/50 backdrop-blur-sm border border-gray-700 rounded-2xl p-6 hover:border-teal-400/50 hover:bg-navy-800/70 transition-all duration-300 h-full"
        >
          <div
            class="w-12 h-12 bg-electric-400/10 rounded-lg flex items-center justify-center mb-5 border border-electric-400/20"
          >
            <svg
              class="w-6 h-6 text-electric-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-100 mb-3">
            Desenvolvimento Sob Medida
          </h3>
          <p class="text-sm text-gray-400 leading-relaxed">
            Criamos soluções de IA específicas para seu negócio, seus desafios e
            suas oportunidades únicas.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
