---

<section id="services" class="py-32 bg-navy-900/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-20">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 text-white">
        Where We Create <span class="text-teal-400">Leverage</span>
      </h2>
      <p class="text-lg sm:text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
        Three integrated systems that eliminate manual friction and scale your operations
      </p>
    </div>

    <!-- Three Pillars Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Pillar 1 - Pipeline Integrity -->
      <div class="relative group scroll-reveal">
        <div
          class="relative bg-gradient-to-br from-navy-800 to-navy-900 border border-gray-700 rounded-2xl p-8 hover:border-teal-400/50 hover:shadow-xl hover:shadow-teal-400/10 transition-all duration-300 h-full"
        >
          <div class="flex items-start justify-between mb-6">
            <div
              class="w-14 h-14 bg-gradient-to-r from-teal-400 to-teal-500 rounded-xl flex items-center justify-center flex-shrink-0"
            >
              <svg
                class="w-7 h-7 text-navy-950"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"
                ></path>
              </svg>
            </div>
          </div>
          <h3 class="text-2xl sm:text-3xl font-bold text-white mb-4">
            Pipeline Integrity
          </h3>
          <p class="text-lg text-gray-300 mb-6 leading-relaxed">
            Turn noisy inboxes into clean, qualified opportunities. Your team only talks to decision-makers, not noise.
          </p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <svg
                class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-200">Automated lead qualification & scoring</span>
            </li>
            <li class="flex items-start gap-3">
              <svg
                class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-200">Intelligent routing to the right rep</span>
            </li>
            <li class="flex items-start gap-3">
              <svg
                class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-200">CRM sync & handoff automation</span>
            </li>
            <li class="flex items-start gap-3">
              <svg
                class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-200">Persistent, personalized follow-up</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Pillar 2 - Operational Capacity -->
      <div class="relative group scroll-reveal stagger-1">
        <div
          class="relative bg-gradient-to-br from-navy-800 to-navy-900 border-2 border-teal-400/50 rounded-2xl p-8 hover:border-teal-400 hover:shadow-xl hover:shadow-teal-400/20 transition-all duration-300 h-full"
        >
          <div class="flex items-start justify-between mb-6">
            <div
              class="w-14 h-14 bg-gradient-to-r from-teal-400 to-electric-400 rounded-xl flex items-center justify-center flex-shrink-0"
            >
              <svg
                class="w-7 h-7 text-navy-950"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 10V3L4 14h7v7l9-11h-7z"
                ></path>
              </svg>
            </div>
            <span
              class="inline-flex items-center px-3 py-1 bg-teal-400/10 text-teal-400 text-xs font-semibold rounded-full border border-teal-400/20"
            >
              Biggest Impact
            </span>
          </div>
          <h3 class="text-2xl sm:text-3xl font-bold text-white mb-4">
            Operational Capacity
          </h3>
          <p class="text-lg text-gray-300 mb-6 leading-relaxed">
            Automate the boring but critical admin work. Scale revenue without adding headcount.
          </p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <svg
                class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-200">Document processing & data entry</span>
            </li>
            <li class="flex items-start gap-3">
              <svg
                class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-200">Automated follow-ups & reminders</span>
            </li>
            <li class="flex items-start gap-3">
              <svg
                class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-200">Cross-system data syncing</span>
            </li>
            <li class="flex items-start gap-3">
              <svg
                class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-200">Tool integration (CRM, email, scheduling)</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Pillar 3 - Asset Reactivation -->
      <div class="relative group scroll-reveal stagger-2">
        <div
          class="relative bg-gradient-to-br from-navy-800 to-navy-900 border border-gray-700 rounded-2xl p-8 hover:border-electric-400/50 hover:shadow-xl hover:shadow-electric-400/10 transition-all duration-300 h-full"
        >
          <div class="flex items-start justify-between mb-6">
            <div
              class="w-14 h-14 bg-gradient-to-r from-electric-400 to-electric-500 rounded-xl flex items-center justify-center flex-shrink-0"
            >
              <svg
                class="w-7 h-7 text-navy-950"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                ></path>
              </svg>
            </div>
          </div>
          <h3 class="text-2xl sm:text-3xl font-bold text-white mb-4">
            Asset Reactivation
          </h3>
          <p class="text-lg text-gray-300 mb-6 leading-relaxed">
            Your CRM holds untapped revenue. Surface opportunities you've already paid for but haven't acted on.
          </p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <svg
                class="w-5 h-5 text-electric-400 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-200">Dormant lead identification</span>
            </li>
            <li class="flex items-start gap-3">
              <svg
                class="w-5 h-5 text-electric-400 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-200">Automated re-engagement campaigns</span>
            </li>
            <li class="flex items-start gap-3">
              <svg
                class="w-5 h-5 text-electric-400 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-200">Win-back sequences & timing optimization</span>
            </li>
            <li class="flex items-start gap-3">
              <svg
                class="w-5 h-5 text-electric-400 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-200">Revenue recovery tracking</span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-16">
      <p class="text-gray-400 mb-6 max-w-2xl mx-auto">
        Each system is custom-built for your specific bottlenecks — not a template plugged in and walked away from.
      </p>
      <a
        href="#contact"
        class="inline-flex items-center text-teal-400 hover:text-teal-300 font-medium group"
      >
        Find out which system fits your operation
        <svg
          class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</section>
