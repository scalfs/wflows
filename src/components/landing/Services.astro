---
---

<section id="services" class="py-24 bg-navy-900/50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        Nossos <span class="text-gradient">Flows</span>
      </h2>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        Sistemas de IA que transformam operações manuais em flows inteligentes
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Lead Flow -->
      <div class="relative group">
        <div class="absolute inset-0 bg-gradient-to-r from-teal-600/20 to-electric-600/20 rounded-2xl blur-xl group-hover:blur-2xl transition-all duration-300"></div>
        <div class="relative bg-navy-800/50 backdrop-blur-sm border border-gray-800 rounded-2xl p-8 hover:border-teal-400/50 transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-r from-teal-400 to-electric-400 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-navy-950" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-100 mb-4">Lead Flow</h3>
          <p class="text-gray-400 mb-6">
            Recepcionista AI 24/7 que nunca perde uma oportunidade. Atende por telefone, WhatsApp e chat.
          </p>
          <ul class="space-y-2 text-sm text-gray-400">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Qualificação automática de leads</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Agendamento direto na agenda</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Integração com seu CRM</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Voice Flow -->
      <div class="relative group">
        <div class="absolute inset-0 bg-gradient-to-r from-electric-600/20 to-teal-600/20 rounded-2xl blur-xl group-hover:blur-2xl transition-all duration-300"></div>
        <div class="relative bg-navy-800/50 backdrop-blur-sm border border-gray-800 rounded-2xl p-8 hover:border-electric-400/50 transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-r from-electric-400 to-teal-400 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-navy-950" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-100 mb-4">Voice Flow</h3>
          <p class="text-gray-400 mb-6">
            Atendimento por voz com IA conversacional natural. Seus clientes nem percebem que é um robô.
          </p>
          <ul class="space-y-2 text-sm text-gray-400">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-electric-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Conversa natural em português</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-electric-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Atende múltiplas ligações</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-electric-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Transcrição e análise de chamadas</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Sales Flow -->
      <div class="relative group">
        <div class="absolute inset-0 bg-gradient-to-r from-teal-600/20 to-electric-600/20 rounded-2xl blur-xl group-hover:blur-2xl transition-all duration-300"></div>
        <div class="relative bg-navy-800/50 backdrop-blur-sm border border-gray-800 rounded-2xl p-8 hover:border-teal-400/50 transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-r from-teal-400 to-electric-400 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-navy-950" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-100 mb-4">Sales Flow</h3>
          <p class="text-gray-400 mb-6">
            Reativa leads esquecidos e nutre prospects automaticamente até a conversão.
          </p>
          <ul class="space-y-2 text-sm text-gray-400">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Campanhas de reativação</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Follow-up inteligente</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Upsell e cross-sell automático</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>