---
---

<section id="use-cases" class="py-24 bg-navy-900/50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        Casos de <span class="text-gradient">Sucesso</span>
      </h2>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        Soluções específicas para cada vertical de negócio
      </p>
    </div>

    <div class="space-y-12">
      <!-- Restaurants -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
        <div>
          <div class="inline-flex items-center px-3 py-1 bg-teal-400/10 text-teal-400 text-sm font-medium rounded-full mb-4">
            Restaurantes
          </div>
          <h3 class="text-3xl font-bold text-gray-100 mb-4">
            Pedidos Automáticos 24/7
          </h3>
          <p class="text-gray-400 mb-6">
            Receba pedidos por telefone e WhatsApp a qualquer hora. Nosso agente de IA conversa naturalmente com clientes, sugere pratos, informa sobre promoções e envia pedidos direto para a cozinha.
          </p>
          <ul class="space-y-3 text-gray-400">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Integração com sistemas de pedidos existentes</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Cardápio conversacional com recomendações</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Confirmação automática e tempo de entrega</span>
            </li>
          </ul>
        </div>
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-r from-teal-600/20 to-electric-600/20 rounded-2xl blur-2xl"></div>
          <div class="relative bg-navy-800/50 backdrop-blur-sm border border-gray-800 rounded-2xl p-8">
            <div class="text-center">
              <div class="text-5xl mb-4">🍕</div>
              <p class="text-2xl font-bold text-gray-100 mb-2">+47%</p>
              <p class="text-gray-400">Aumento em pedidos noturnos</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Clinics -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
        <div class="order-2 lg:order-1">
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-r from-electric-600/20 to-teal-600/20 rounded-2xl blur-2xl"></div>
            <div class="relative bg-navy-800/50 backdrop-blur-sm border border-gray-800 rounded-2xl p-8">
              <div class="text-center">
                <div class="text-5xl mb-4">🏥</div>
                <p class="text-2xl font-bold text-gray-100 mb-2">-82%</p>
                <p class="text-gray-400">Redução de faltas em consultas</p>
              </div>
            </div>
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center px-3 py-1 bg-electric-400/10 text-electric-400 text-sm font-medium rounded-full mb-4">
            Clínicas e Consultórios
          </div>
          <h3 class="text-3xl font-bold text-gray-100 mb-4">
            Agendamento Inteligente
          </h3>
          <p class="text-gray-400 mb-6">
            Recepcionista virtual que agenda, confirma e reagenda consultas. Envia lembretes, responde dúvidas sobre preparos e reduz drasticamente o no-show.
          </p>
          <ul class="space-y-3 text-gray-400">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-electric-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Sincronização com agenda médica</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-electric-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Confirmação automática 24h antes</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-electric-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Lista de espera inteligente</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Solar -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
        <div>
          <div class="inline-flex items-center px-3 py-1 bg-teal-400/10 text-teal-400 text-sm font-medium rounded-full mb-4">
            Energia Solar
          </div>
          <h3 class="text-3xl font-bold text-gray-100 mb-4">
            Qualificação e Vendas B2B
          </h3>
          <p class="text-gray-400 mb-6">
            Atendimento especializado para engenheiros e instaladores. Qualifica leads técnicos, agenda demonstrações e acompanha todo o ciclo de vendas complexas B2B.
          </p>
          <ul class="space-y-3 text-gray-400">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Atendimento técnico especializado</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Gestão de reclamações e SAC</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Follow-up automatizado pós-venda</span>
            </li>
          </ul>
        </div>
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-r from-teal-600/20 to-electric-600/20 rounded-2xl blur-2xl"></div>
          <div class="relative bg-navy-800/50 backdrop-blur-sm border border-gray-800 rounded-2xl p-8">
            <div class="text-center">
              <div class="text-5xl mb-4">☀️</div>
              <p class="text-2xl font-bold text-gray-100 mb-2">3x</p>
              <p class="text-gray-400">Mais conversões em vendas B2B</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>