---

---

<section id="use-cases" class="py-24 bg-navy-900/50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        Casos de <span class="text-gradient">Sucesso</span>
      </h2>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        Como nossos sistemas de IA preditiva e automação comercial transformam
        resultados em diferentes setores
      </p>
    </div>

    <div class="space-y-12">
      <!-- Restaurants -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
        <div>
          <div
            class="inline-flex items-center px-3 py-1 bg-teal-400/10 text-teal-400 text-sm font-medium rounded-full mb-4"
          >
            Restaurantes
          </div>
          <h3 class="text-3xl font-bold text-gray-100 mb-4">
            Análise Preditiva de Demanda
          </h3>
          <p class="text-gray-400 mb-6">
            Sistemas que analisam histórico de pedidos, sazonalidade e
            comportamento para prever demanda e otimizar estoque. SDR artificial
            qualifica leads e agenda entregas automaticamente.
          </p>
          <ul class="space-y-3 text-gray-400">
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-teal-400 shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Previsão de demanda por horário e dia da semana</span>
            </li>
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-teal-400 shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Qualificação e agendamento automático de pedidos</span>
            </li>
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-teal-400 shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Otimização de ROI por canal de marketing</span>
            </li>
          </ul>
        </div>
        <div class="relative">
          <div
            class="absolute inset-0 bg-gradient-to-r from-teal-600/20 to-electric-600/20 rounded-2xl blur-2xl"
          >
          </div>
          <div
            class="relative bg-navy-800/50 backdrop-blur-sm border border-gray-800 rounded-2xl p-8"
          >
            <div class="text-center">
              <div class="text-5xl mb-4">🍕</div>
              <p class="text-2xl font-bold text-gray-100 mb-2">+35%</p>
              <p class="text-gray-400">Aumento em ROI de marketing</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Clinics -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
        <div class="order-2 lg:order-1">
          <div class="relative">
            <div
              class="absolute inset-0 bg-gradient-to-r from-electric-600/20 to-teal-600/20 rounded-2xl blur-2xl"
            >
            </div>
            <div
              class="relative bg-navy-800/50 backdrop-blur-sm border border-gray-800 rounded-2xl p-8"
            >
              <div class="text-center">
                <div class="text-5xl mb-4">🏥</div>
                <p class="text-2xl font-bold text-gray-100 mb-2">3x</p>
                <p class="text-gray-400">
                  Mais conversões com nutrição inteligente
                </p>
              </div>
            </div>
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <div
            class="inline-flex items-center px-3 py-1 bg-electric-400/10 text-electric-400 text-sm font-medium rounded-full mb-4"
          >
            Clínicas e Consultórios
          </div>
          <h3 class="text-3xl font-bold text-gray-100 mb-4">
            SDR Artificial e Nutrição de Leads
          </h3>
          <p class="text-gray-400 mb-6">
            SDR artificial 24/7 que qualifica leads, agenda consultas e nutre
            pacientes automaticamente. Sistema preditivo identifica pacientes
            com maior probabilidade de conversão e otimiza timing de abordagem.
          </p>
          <ul class="space-y-3 text-gray-400">
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-electric-400 shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Qualificação inteligente e agendamento automático</span>
            </li>
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-electric-400 shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Lead scoring dinâmico e segmentação comportamental</span>
            </li>
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-electric-400 shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Sequências de nutrição personalizadas até conversão</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Solar -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
        <div>
          <div
            class="inline-flex items-center px-3 py-1 bg-teal-400/10 text-teal-400 text-sm font-medium rounded-full mb-4"
          >
            Energia Solar
          </div>
          <h3 class="text-3xl font-bold text-gray-100 mb-4">
            Automação Comercial Completa B2B
          </h3>
          <p class="text-gray-400 mb-6">
            Análise preditiva identifica oportunidades de maior valor. Automação
            comercial completa: prospecção multicanal, qualificação técnica,
            sequências de vendas personalizadas e acompanhamento pós-venda
            automático.
          </p>
          <ul class="space-y-3 text-gray-400">
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-teal-400 shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Previsão de ROI por canal e identificação de gargalos</span>
            </li>
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-teal-400 shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span
                >Prospecção automatizada e sequências de vendas personalizadas</span
              >
            </li>
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-teal-400 shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span
                >Relatórios de performance em tempo real e dashboards executivos</span
              >
            </li>
          </ul>
        </div>
        <div class="relative">
          <div
            class="absolute inset-0 bg-gradient-to-r from-teal-600/20 to-electric-600/20 rounded-2xl blur-2xl"
          >
          </div>
          <div
            class="relative bg-navy-800/50 backdrop-blur-sm border border-gray-800 rounded-2xl p-8"
          >
            <div class="text-center">
              <div class="text-5xl mb-4">☀️</div>
              <p class="text-2xl font-bold text-gray-100 mb-2">5x</p>
              <p class="text-gray-400">ROI com automação comercial completa</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
