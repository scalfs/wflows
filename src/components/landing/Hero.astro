---

---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16"
>
  <!-- Background gradient effect -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900 to-navy-950"
  >
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-20">
    <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold mb-8 tracking-tight">
      <span class="block text-white animate-hero-headline">Scale Revenue</span>
      <span class="block text-gradient mt-2 animate-hero-headline stagger-1">Without Scaling Headcount</span>
    </h1>

    <p class="text-xl sm:text-2xl md:text-3xl text-gray-200 font-medium mb-6 max-w-4xl mx-auto leading-relaxed animate-hero-subheading stagger-2">
      AI infrastructure that eliminates manual friction and builds predictable, scalable operations for growing businesses.
    </p>

    <p class="text-base sm:text-lg text-gray-400 mb-12 max-w-3xl mx-auto leading-relaxed animate-fade-in stagger-3">
      Most teams hit a ceiling they can't see. It's not a lack of effort — it's a lack of leverage. 
      Leads slip through cracks. Data entry eats 20+ hours a week. Operations can't keep pace with growth. 
      We diagnose where your team bleeds time, then build automated systems to handle it.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-20 animate-fade-in stagger-4">
      <a
        href="#contact"
        class="inline-flex items-center justify-center px-8 py-4 text-base sm:text-lg font-semibold text-navy-950 bg-gradient-to-r from-teal-400 to-electric-400 rounded-xl hover:from-teal-300 hover:to-electric-300 hover:scale-105 active:scale-100 shadow-lg hover:shadow-teal-400/50 min-w-[200px]"
      >
        <svg
          class="w-5 h-5 mr-2 flex-shrink-0"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"
          ></path>
        </svg>
        Get a Free Operations Audit
      </a>
      <a
        href="#services"
        class="inline-flex items-center justify-center px-8 py-4 text-base sm:text-lg font-semibold text-white border-2 border-gray-600 rounded-xl hover:border-teal-400 hover:text-teal-400 hover:bg-teal-400/5 active:scale-95 min-w-[200px]"
      >
        See How It Works
      </a>
    </div>

    <!-- Trust indicators -->
    <div class="flex flex-col sm:flex-row flex-wrap justify-center gap-6 sm:gap-8 text-gray-300 animate-fade-in stagger-5">
      <div class="flex items-center justify-center gap-2.5">
        <svg
          class="w-5 h-5 text-teal-400 flex-shrink-0"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
        </svg>
        <span class="text-sm sm:text-base">Engineered for reliability, not templates</span>
      </div>
      <div class="flex items-center justify-center gap-2.5">
        <svg
          class="w-5 h-5 text-teal-400 flex-shrink-0"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"></path>
        </svg>
        <span class="text-sm sm:text-base">Integrates with your existing CRM & tools</span>
      </div>
      <div class="flex items-center justify-center gap-2.5">
        <svg
          class="w-5 h-5 text-teal-400 flex-shrink-0"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
        </svg>
        <span class="text-sm sm:text-base">8+ years Fintech & SaaS systems background</span>
      </div>
    </div>
  </div>
</section>
