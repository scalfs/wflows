---

---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16"
>
  <!-- Background gradient effect -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900 to-navy-950"
  >
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-20">
    <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold mb-8 tracking-tight">
      <span class="block text-white animate-hero-headline">Win More with</span>
      <span class="block text-gradient mt-2 animate-hero-headline stagger-1">Better Flows</span>
    </h1>

    <p class="text-xl sm:text-2xl md:text-3xl text-gray-200 font-medium mb-6 max-w-4xl mx-auto leading-relaxed animate-hero-subheading stagger-2">
      Construímos workflows com IA que capturam leads, atendem clientes e geram
      receita — automaticamente.
    </p>

    <p class="text-base sm:text-lg text-gray-400 mb-12 max-w-2xl mx-auto leading-relaxed animate-fade-in stagger-3">
      Atendimento por voz e WhatsApp 24/7. Agendamentos automáticos. Captação e
      nutrição inteligente. Reativação de leads esquecidos. Automação comercial
      completa. Tudo integrado ao seu CRM.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-20 animate-fade-in stagger-4">
      <a
        href="#contact"
        class="inline-flex items-center justify-center px-8 py-4 text-base sm:text-lg font-semibold text-navy-950 bg-gradient-to-r from-teal-400 to-electric-400 rounded-xl hover:from-teal-300 hover:to-electric-300 hover:scale-105 active:scale-100 shadow-lg hover:shadow-teal-400/50 min-w-[200px]"
      >
        <svg
          class="w-5 h-5 mr-2 flex-shrink-0"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
          ></path>
        </svg>
        Agendar Consulta
      </a>
      <a
        href="#services"
        class="inline-flex items-center justify-center px-8 py-4 text-base sm:text-lg font-semibold text-white border-2 border-gray-600 rounded-xl hover:border-teal-400 hover:text-teal-400 hover:bg-teal-400/5 active:scale-95 min-w-[200px]"
      >
        Conhecer Serviços
      </a>
    </div>

    <!-- Trust indicators -->
    <div class="flex flex-col sm:flex-row flex-wrap justify-center gap-6 sm:gap-8 text-gray-300 animate-fade-in stagger-5">
      <div class="flex items-center justify-center gap-2.5">
        <svg
          class="w-5 h-5 text-teal-400 flex-shrink-0"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M5 13l4 4L19 7"></path>
        </svg>
        <span class="text-sm sm:text-base">Integração com CRMs existentes</span>
      </div>
      <div class="flex items-center justify-center gap-2.5">
        <svg
          class="w-5 h-5 text-teal-400 flex-shrink-0"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M5 13l4 4L19 7"></path>
        </svg>
        <span class="text-sm sm:text-base">Atendimento por voz e WhatsApp</span>
      </div>
      <div class="flex items-center justify-center gap-2.5">
        <svg
          class="w-5 h-5 text-teal-400 flex-shrink-0"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M5 13l4 4L19 7"></path>
        </svg>
        <span class="text-sm sm:text-base">Automação comercial completa</span>
      </div>
    </div>
  </div>
</section>
