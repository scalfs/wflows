---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background gradient effect -->
  <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900 to-navy-950"></div>

  <!-- Animated gradient orbs -->
  <div class="absolute top-20 left-20 w-96 h-96 bg-teal-500/20 rounded-full blur-3xl animate-pulse-slow"></div>
  <div class="absolute bottom-20 right-20 w-96 h-96 bg-electric-500/20 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 1.5s;"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 text-center">
    <h1 class="text-5xl md:text-7xl font-bold mb-6">
      <span class="block">Win More with</span>
      <span class="block text-gradient">Better Flows</span>
    </h1>

    <p class="text-xl md:text-2xl text-gray-300 mb-8 max-w-3xl mx-auto">
      Construímos workflows com IA que capturam leads, atendem clientes e geram receita — automaticamente.
    </p>

    <p class="text-lg text-gray-400 mb-12 max-w-2xl mx-auto">
      Atendimento por voz e WhatsApp 24/7. Agendamentos automáticos.
      Reativação de leads esquecidos. Tudo integrado ao seu CRM.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#contact"
        class="inline-flex items-center justify-center px-8 py-4 text-lg font-medium text-navy-950 bg-gradient-to-r from-teal-400 to-electric-400 rounded-xl hover:from-teal-300 hover:to-electric-300 transition-all duration-200 shadow-lg hover:shadow-teal-400/30 scroll-smooth"
      >
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
        Agendar Demonstração Gratuita
      </a>
      <a
        href="#services"
        class="inline-flex items-center justify-center px-8 py-4 text-lg font-medium text-gray-100 border-2 border-gray-700 rounded-xl hover:border-teal-400 hover:text-teal-400 transition-all duration-200 scroll-smooth"
      >
        Conhecer Serviços
      </a>
    </div>

    <!-- Trust indicators -->
    <div class="mt-16 flex flex-wrap justify-center gap-8 text-gray-400 text-sm">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
        <span>Integração com CRMs existentes</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
        <span>Atendimento por voz e WhatsApp</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
        <span>Setup em 7 dias</span>
      </div>
    </div>
  </div>
</section>