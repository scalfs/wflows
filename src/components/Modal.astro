---
---

<div class="modal-overlay" id="modal-overlay" style={{display:'none'}}>
  <div class="modal-content" id="modal-content">
    <div id="modal-steps">
      <div style={{display:'flex', gap:6, marginBottom: 28}}>
        <div class="modal-progress-bar" data-step="0"></div>
        <div class="modal-progress-bar" data-step="1"></div>
        <div class="modal-progress-bar" data-step="2"></div>
      </div>
      <span class="kicker" id="modal-kicker">Step 1 of 3</span>
      <h3 style={{marginTop: 8, marginBottom: 24}} id="modal-title">What revenue motion needs a flow?</h3>
      <div style={{display:'grid', gap:10}} id="modal-options">
        <button class="btn btn-secondary modal-option" data-step="0">
          <span>Outbound to enterprise</span><span style={{opacity:0.5}}>→</span>
        </button>
        <button class="btn btn-secondary modal-option" data-step="0">
          <span>Inbound qualification</span><span style={{opacity:0.5}}>→</span>
        </button>
        <button class="btn btn-secondary modal-option" data-step="0">
          <span>Voice for support</span><span style={{opacity:0.5}}>→</span>
        </button>
        <button class="btn btn-secondary modal-option" data-step="0">
          <span>Pipeline hygiene</span><span style={{opacity:0.5}}>→</span>
        </button>
      </div>
    </div>
    <div id="modal-success" style={{display:'none', textAlign:'center', padding:'12px 0'}}>
      <div style={{width:64, height:64, borderRadius:9999, background:'var(--wf-primary)', margin:'0 auto 24px', display:'flex', alignItems:'center', justifyContent:'center', boxShadow:'var(--wf-shadow-glow)'}}>
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#fff" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <h3 style={{marginBottom: 12}}>You're in.</h3>
      <p style={{color:'var(--wf-muted-foreground)', marginBottom: 24}}>
        We'll email you within 24 hours with a session link and a one-page brief tailored to your motion.
      </p>
      <button class="btn btn-primary btn-lg" id="modal-close">Done</button>
    </div>
  </div>
</div>

<script>
  const steps = [
    { title: "What revenue motion needs a flow?", options: ["Outbound to enterprise", "Inbound qualification", "Voice for support", "Pipeline hygiene"] },
    { title: "Which stack are we plugging into?", options: ["HubSpot + Slack", "Salesforce", "Pipedrive", "Custom / other"] },
    { title: "When are you trying to ship?", options: ["This week", "This month", "This quarter", "Just exploring"] },
  ];

  let currentStep = 0;
  const overlay = document.getElementById('modal-overlay');
  const modalContent = document.getElementById('modal-content');
  const modalSteps = document.getElementById('modal-steps');
  const modalSuccess = document.getElementById('modal-success');
  const modalKicker = document.getElementById('modal-kicker');
  const modalTitle = document.getElementById('modal-title');
  const modalOptions = document.getElementById('modal-options');
  const modalClose = document.getElementById('modal-close');
  const progressBars = document.querySelectorAll('.modal-progress-bar');

  function openModal() {
    currentStep = 0;
    overlay.style.display = 'flex';
    modalSteps.style.display = 'block';
    modalSuccess.style.display = 'none';
    updateStep();
  }

  function closeModal() {
    overlay.style.display = 'none';
  }

  function updateStep() {
    const s = steps[currentStep];
    modalKicker.textContent = `Step ${currentStep + 1} of ${steps.length}`;
    modalTitle.textContent = s.title;
    modalOptions.innerHTML = s.options.map((o, i) => `
      <button class="btn btn-secondary modal-option" data-step="${currentStep}">
        <span>${o}</span><span style="opacity:0.5">→</span>
      </button>
    `).join('');
    progressBars.forEach((bar, i) => {
      bar.style.flex = '1';
      bar.style.height = '4px';
      bar.style.borderRadius = '9999px';
      bar.style.background = i <= currentStep ? 'var(--wf-primary)' : 'var(--wf-border)';
      bar.style.transition = 'background 200ms var(--ease-out)';
    });
    document.querySelectorAll('.modal-option').forEach(btn => {
      btn.addEventListener('click', handleOptionClick);
    });
  }

  function handleOptionClick() {
    currentStep++;
    if (currentStep >= steps.length) {
      modalSteps.style.display = 'none';
      modalSuccess.style.display = 'block';
    } else {
      updateStep();
    }
  }

  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeModal();
  });
  modalClose.addEventListener('click', closeModal);

  // Expose openModal globally
  window.openModal = openModal;

  // Attach to CTA buttons
  document.getElementById('nav-cta')?.addEventListener('click', openModal);
  document.getElementById('hero-cta')?.addEventListener('click', openModal);
  document.getElementById('cta-btn')?.addEventListener('click', openModal);
</script>

<style>
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(10, 21, 32, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
    padding: 24px;
    animation: fadeIn 200ms ease-out;
  }
  .modal-content {
    background: #fff;
    border-radius: 32px;
    width: min(560px, 100%);
    padding: 40px;
    box-shadow: var(--wf-shadow-floating);
  }
</style>
