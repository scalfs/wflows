---
import CalEmbed from "./CalEmbed.astro";
---

<section
  id="contact"
  class="py-24 bg-gradient-to-br from-navy-900 to-navy-950 relative overflow-hidden"
>
  <!-- Background effects -->
  <div
    class="absolute top-0 left-1/4 w-96 h-96 bg-teal-500/10 rounded-full blur-3xl animate-pulse-slow"
  >
  </div>
  <div
    class="absolute bottom-0 right-1/4 w-96 h-96 bg-electric-500/10 rounded-full blur-3xl animate-pulse-slow"
    style="animation-delay: 2s;"
  >
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 lg:px-8 text-center">
    <h2 class="text-4xl md:text-6xl font-bold mb-6">
      See Where Your <span class="text-gradient">Bottlenecks</span> Are
    </h2>

    <p class="text-xl md:text-2xl text-gray-300 mb-8">
      Book a free 30-minute Operations Audit. We'll identify your top 3 time-draining bottlenecks and show you exactly how to remove them — whether you work with us or not.
    </p>

    <div
      class="bg-navy-800/50 backdrop-blur-sm border border-gray-800 rounded-2xl p-8 mb-8"
    >
      <h3 class="text-2xl font-bold text-gray-100 mb-6">
        What You'll Get:
      </h3>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-left">
        <div class="flex items-start gap-3">
          <svg
            class="w-6 h-6 text-teal-400 shrink-0 mt-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <h4 class="font-semibold text-gray-100">Bottleneck Identification</h4>
            <p class="text-gray-400">
              Pinpoint exactly where your team bleeds time on repetitive, low-value tasks
            </p>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <svg
            class="w-6 h-6 text-electric-400 shrink-0 mt-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <h4 class="font-semibold text-gray-100">Automation Opportunity Map</h4>
            <p class="text-gray-400">
              Clear view of which processes can be automated and the impact of each
            </p>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <svg
            class="w-6 h-6 text-teal-400 shrink-0 mt-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <h4 class="font-semibold text-gray-100">ROI Estimate</h4>
            <p class="text-gray-400">
              Projected time savings and revenue impact for each quick win
            </p>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <svg
            class="w-6 h-6 text-electric-400 shrink-0 mt-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <h4 class="font-semibold text-gray-100">Actionable Next Steps</h4>
            <p class="text-gray-400">
              Concrete recommendations you can act on immediately
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Cal.com Inline Embed -->
    <div
      class="bg-navy-800/30 backdrop-blur-sm border border-gray-800/50 rounded-2xl p-6 pb-0 mb-8"
    >
      <h3 class="text-2xl font-bold text-gray-100 mb-2 text-center">
        Book Your Free Audit
      </h3>
      <div class="text-center">
        <p class="text-gray-500 text-sm mb-4">
          No commitment required • 30-minute call • Valuable whether we work together or not
        </p>
      </div>
      <!-- Cal.com embed using Astro Islands Architecture -->
      <CalEmbed client:visible />
    </div>
  </div>
</section>
