---
import CalEmbed from "./CalEmbed.astro";
---

<section
  id="contact"
  class="py-24 bg-gradient-to-br from-navy-900 to-navy-950 relative overflow-hidden"
>
  <!-- Background effects -->
  <div
    class="absolute top-0 left-1/4 w-96 h-96 bg-teal-500/10 rounded-full blur-3xl animate-pulse-slow"
  >
  </div>
  <div
    class="absolute bottom-0 right-1/4 w-96 h-96 bg-electric-500/10 rounded-full blur-3xl animate-pulse-slow"
    style="animation-delay: 2s;"
  >
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 lg:px-8 text-center">
    <h2 class="text-4xl md:text-6xl font-bold mb-6">
      Pronto para <span class="text-gradient">Multiplicar</span>?
    </h2>

    <p class="text-xl md:text-2xl text-gray-300 mb-8">
      Agende uma consulta gratuita e veja como nossos sistemas de IA preditiva e
      automação comercial podem transformar seus resultados
    </p>

    <div
      class="bg-navy-800/50 backdrop-blur-sm border border-gray-800 rounded-2xl p-8 mb-8"
    >
      <h3 class="text-2xl font-bold text-gray-100 mb-6">
        O que você receberá:
      </h3>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-left">
        <div class="flex items-start gap-3">
          <svg
            class="w-6 h-6 text-teal-400 shrink-0 mt-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <h4 class="font-semibold text-gray-100">Análise Preditiva</h4>
            <p class="text-gray-400">
              Identificação de oportunidades e gargalos nos seus dados
              comerciais
            </p>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <svg
            class="w-6 h-6 text-electric-400 shrink-0 mt-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <h4 class="font-semibold text-gray-100">Consulta Personalizada</h4>
            <p class="text-gray-400">
              Análise específica do seu negócio e como nossos sistemas podem
              ajudar
            </p>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <svg
            class="w-6 h-6 text-teal-400 shrink-0 mt-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <h4 class="font-semibold text-gray-100">Plano Personalizado</h4>
            <p class="text-gray-400">Estratégia específica para seu negócio</p>
          </div>
        </div>

        <div class="flex items-start gap-3">
          <svg
            class="w-6 h-6 text-electric-400 shrink-0 mt-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <h4 class="font-semibold text-gray-100">ROI Projetado</h4>
            <p class="text-gray-400">
              Estimativa de retorno e redução de custos
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Cal.com Inline Embed -->
    <div
      class="bg-navy-800/30 backdrop-blur-sm border border-gray-800/50 rounded-2xl p-6 pb-0 mb-8"
    >
      <h3 class="text-2xl font-bold text-gray-100 mb-2 text-center">
        Agende sua Consulta
      </h3>
      <div class="text-center">
        <p class="text-gray-500 text-sm mb-4">
          Sem compromisso • Consulta de 30 minutos • Análise gratuita
        </p>
      </div>
      <!-- Cal.com embed using Astro Islands Architecture -->
      <CalEmbed client:visible />
    </div>
  </div>
</section>
