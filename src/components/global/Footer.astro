<footer class="bg-navy-950 border-t border-gray-800/50 mt-24">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Company Info -->
      <div>
        <h3 class="text-2xl font-bold mb-4">
          <span class="text-teal-400 group-hover:text-teal-300"
            >W<span class="text-gray-100 group-hover:text-white">Flows</span
            ></span
          >
        </h3>
        <p class="text-gray-400 text-sm">
          AI infrastructure that eliminates manual friction and builds
          predictable, scalable operations for growing businesses.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-gray-100 font-semibold mb-4">Quick Links</h4>
        <ul class="space-y-2">
          <li>
            <a
              href="#services"
              class="text-gray-400 hover:text-teal-400 text-sm transition-colors"
            >
              Services
            </a>
          </li>
          <li>
            <a
              href="#how-it-works"
              class="text-gray-400 hover:text-teal-400 text-sm transition-colors"
            >
              How It Works
            </a>
          </li>
          <li>
            <a
              href="#use-cases"
              class="text-gray-400 hover:text-teal-400 text-sm transition-colors"
            >
              Use Cases
            </a>
          </li>
          <li>
            <a
              href="#about"
              class="text-gray-400 hover:text-teal-400 text-sm transition-colors"
            >
              About
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-gray-100 font-semibold mb-4">Get Started</h4>
        <p class="text-gray-400 text-sm mb-4">
          Ready to see where your bottlenecks are? Book a free operations audit.
        </p>
        <a
          href="#contact"
          class="inline-flex items-center text-teal-400 hover:text-teal-300 text-sm font-medium transition-colors"
        >
          Schedule Audit
          <svg
            class="w-4 h-4 ml-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-gray-800/50">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-gray-500 text-sm">© 2025 WFlows. All rights reserved.</p>
        <div class="flex gap-6">
          <a
            href="/privacy-policy"
            class="text-gray-500 hover:text-teal-400 text-sm transition-colors"
          >
            Privacy Policy
          </a>
          <a
            href="/terms-of-service"
            class="text-gray-500 hover:text-teal-400 text-sm transition-colors"
          >
            Terms of Service
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
