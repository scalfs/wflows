---
const WA_HREF = "https://wa.me/5527997402481?text=Hi%21%20I%27d%20like%20to%20book%20a%20free%20automation%20audit.";
---

<section class="section-dark" id="guarantee">
  <div class="container">
    <div class="guarantee-block">
      <span class="kicker">Our promise</span>
      <h2>$30,000 in recovered time<br/>within 90 days — guaranteed.</h2>
      <p class="subhead" style={{color:'rgba(246,250,252,0.8)', maxWidth:580}}>
        If we don't deliver measurable ROI in your first 90 days, we keep working until we do. No extra charge. No excuses.
      </p>
      <a class="btn btn-primary btn-lg" href={WA_HREF} target="_blank" rel="noopener">Claim your free audit call →</a>
      <p class="guarantee-footnote">Month-to-month. No long-term contracts. You own everything we build.</p>
    </div>
  </div>
</section>
